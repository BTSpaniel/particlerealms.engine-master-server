PARTICLE_NODE_ID=particle-node-ca-1
PARTICLE_PUBLIC_BASE_URL=https://discovery.example.com
PARTICLE_PUBLIC_WS_URL=wss://discovery.example.com/v2/ws
PARTICLE_PUBLIC_V1_WS_URL=wss://discovery.example.com/v1/ws
PARTICLE_PUBLIC_NODE_WS_URL=wss://node-discovery.example.com/v2/node
PARTICLE_ADVERTISE_V2=true
PARTICLE_SIGNING_KEY_FILE=/etc/particle-masterserver/node-signing-key.pem
PARTICLE_REQUIRE_CONFIGURED_SIGNING_KEY=true
PARTICLE_NETWORK_ROOT_ID=particle-network-root-v1
PARTICLE_NETWORK_ROOT_VERSION=1
PARTICLE_NETWORK_ROOT_ROLLBACK_VERSION=0
PARTICLE_SIGNING_KEY_ACTIVATES_AT=0
PARTICLE_SIGNING_KEY_EXPIRES_AT=2147483647
PARTICLE_ALLOWED_ORIGINS_JSON=["https://example.com"]
PARTICLE_METRICS_TOKEN=replace-with-a-random-admin-token
PARTICLE_TURN_URLS_JSON=["turn:turn.example.com:3478?transport=udp","turns:turn.example.com:5349"]
PARTICLE_TURN_SHARED_SECRET=replace-with-the-coturn-static-auth-secret
PARTICLE_TURN_SHARED_SECRETS_JSON=[]
PARTICLE_TURN_USERNAME_PREFIX=particle
PARTICLE_TURN_TTL_SECONDS=600
PARTICLE_NODE_MESH_ENABLED=false
PARTICLE_NODE_MESH_MEMBERSHIP_EPOCH=1
PARTICLE_NODE_MESH_SUSPICION_SECONDS=10
PARTICLE_NODE_MESH_MAX_CLOCK_SKEW_SECONDS=30
PARTICLE_NODE_MESH_MAX_PENDING_OPERATIONS=1024
PARTICLE_NODE_MESH_MAX_ROUTE_DESCRIPTORS=16384
PARTICLE_TRUSTED_NODES_JSON=[]
PARTICLE_NODE_MESH_REQUIRE_MTLS=true
PARTICLE_NODE_MESH_CA_FILE=/etc/particle-masterserver/node-mesh-ca.pem
PARTICLE_NODE_MESH_CERT_FILE=/etc/particle-masterserver/node-mesh-client.pem
PARTICLE_NODE_MESH_KEY_FILE=/etc/particle-masterserver/node-mesh-client-key.pem
PARTICLE_NODE_MESH_CLIENT_VERIFY_HEADER=x-ssl-client-verify
PARTICLE_NODE_MESH_CLIENT_VERIFY_VALUE=SUCCESS
PARTICLE_NODE_MESH_PROXY_TOKEN_HEADER=x-particle-node-proxy-token
PARTICLE_NODE_MESH_PROXY_TOKEN=replace-with-a-random-proxy-attestation-token
PARTICLE_MAX_JSON_DEPTH=16
PARTICLE_MAX_JSON_NODES=512
PARTICLE_MAX_DEDUPE_ENTRIES=65536
PARTICLE_ADMISSION_CRYPTO_CONCURRENCY=8
PARTICLE_ADMISSION_CRYPTO_WAIT_SECONDS=0.25
PARTICLE_ADMISSION_RATE_BURST=128
PARTICLE_ADMISSION_RATE_PER_SECOND=2
PARTICLE_ADMISSION_GLOBAL_BURST=256
PARTICLE_ADMISSION_GLOBAL_PER_SECOND=32
PARTICLE_TURN_RATE_BURST=20
PARTICLE_TURN_RATE_PER_SECOND=1
PARTICLE_TURN_GLOBAL_BURST=128
PARTICLE_TURN_GLOBAL_PER_SECOND=16
PARTICLE_SIGNAL_GLOBAL_BURST=512
PARTICLE_SIGNAL_GLOBAL_PER_SECOND=256
PARTICLE_MESSAGE_GLOBAL_BURST=2048
PARTICLE_MESSAGE_GLOBAL_PER_SECOND=1024
PARTICLE_OUTBOUND_SEND_TIMEOUT_SECONDS=5
PARTICLE_READINESS_EVENT_LOOP_P99_SECONDS=0.25
PARTICLE_READINESS_RSS_BYTES=629145600
PARTICLE_READINESS_REQUIRE_TURN=true
